[core]
	editor = vim
	excludesfile = ~/.gitignore
[user]
	name = JP Flouret
	email = jpflouret@gmail.com
	signingkey = 59A10A345D92A6D4E6FEE844355D3022577E04B4!
[alias]
	co = checkout
	ci = commit
	st = status -sb
	d = diff
	dt = difftool -y
	lol = log --graph --decorate --pretty=oneline --abbrev-commit
	lola = log --graph --decorate --pretty=oneline --abbrev-commit --all
	l = log --oneline --decorate
	ll = log --oneline --decorate --all
	unstage = reset HEAD --
	last = log -1 HEAD -p
[merge]
	tool = vimdiff
[diff]
	tool = vimdiff
[branch]
	autosetuprebase = always
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[rerere]
	enabled = true
[commit]
	gpgsign = true
[feature]
	manyFiles = true
[url "git@github.com:jpflouret/"]
	insteadOf = https://github.com/jpflouret/
[include]
	path = ~/.gitconfig.d/local
