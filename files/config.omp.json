{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "console_title_template": "{{.UserName}}@{{.HostName}} {{.Shell}} in {{.PWD}}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "template": " {{.Icon}} {{ if .Env.POSH_GITBASH }}\ue702{{ else if .WSL }}\ue70f{{ end }} ",
          "cache": {
            "duration": "24h",
            "strategy": "session"
          },
          "foreground": "#ffffff",
          "background": "#4754fd",
          "leading_powerline_symbol": "\ue0b6",
          "options": {
            "windows": "\ue70f"
          }
        },
        {
          "type": "shell",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "template": " {{ .Name }} ",
          "foreground": "#ffffff",
          "background": "#0077c2",
          "options": {
            "mapped_shell_names": {
            }
          }
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "template": " {{ if .SSHSession }}\ueba9 {{ .UserName }}@{{ .HostName }}{{ end }} ",
          "foreground": "#ffffff",
          "background": "#e439db"
        },
        {
          "type": "text",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "template": " {{ if .Env.USHELL_UE_PROJECT }} {{ .Env.USHELL_UE_PROJECT }} {{ .Env.USHELL_UE_BRANCH }} {{ end }} ",
          "foreground": "#3b7197",
          "background": "#00f7ff"
        },
        {
          "type": "git",
          "style": "powerline",
          "foreground": "#193549",
          "background": "#05db34",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#FF9248{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#ff4500{{ end }}",
            "{{ if gt .Ahead 0 }}#B388FF{{ end }}",
            "{{ if gt .Behind 0 }}#B388FF{{ end }}"
          ],
          "template": " {{ .UpstreamIcon }} {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "node",
          "style": "powerline",
          "foreground": "#ffffff",
          "background": "#6CA35E",
          "template": " \ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "fetch_version": true
          }
        },
        {
          "type": "go",
          "style": "powerline",
          "foreground": "#111111",
          "background": "#8ED1F7",
          "template": " \ue626 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "fetch_version": true
          }
        },
        {
          "type": "python",
          "style": "powerline",
          "foreground": "#111111",
          "background": "#FFDE57",
          "template": " \ue235  {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "display_mode": "environment",
            "fetch_virtual_env": true
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "foreground": "#ffffff",
          "background": "#8d47ff",
          "template": " \uea83  {{ .Path }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "home_icon": "~",
            "max_depth": 4,
            "style": "agnoster_short"
          }
        },
        {
          "type": "root",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#e43947"
        }
      ]
    }
  ]
}
