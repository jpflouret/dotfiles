{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "console_title_template": "{{ if .Segments.Session.SSHSession }}{{.HostName}} - {{ end }}{{ if .Env.USHELL_UE_PROJECT }}{{ .Env.USHELL_UE_PROJECT }} | {{ .Env.USHELL_UE_BRANCH }} - {{ end }}{{.PWD}}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "template": " {{.Icon}}{{ if .Env.POSH_GITBASH }}\ue702{{ else if .WSL }}\ue70f{{ end }} ",
          "cache": {
            "duration": "24h",
            "strategy": "session"
          },
          "foreground": "#ffffff",
          "background": "#4754fd",
          "leading_powerline_symbol": "\ue0b6",
          "options": {
            "linux": "\ue712",
            "macos": "\ue711",
            "windows": "\ue70f"
          }
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "template": " {{ if .SSHSession }}{{ .HostName }}{{ end }} ",
          "foreground": "#ffffff",
          "background": "#e439db"
        },
        {
          "type": "kubectl",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#2c7cfb",
          "template": " \ue81d {{ .Context }}{{ if ne .Namespace \"default\" }}::{{ .Namespace }}{{ end }} ",
          "options": {
            "context_aliases": {
                "k8s-admin@k8s": "k8s",
                "rpi-admin@rpi_k8s": "rpi"
            },
            "cluster_aliases": {
            }
          }
        },
        {
          "type": "text",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "template": " {{ if .Env.USHELL_UE_PROJECT }} {{ .Env.USHELL_UE_PROJECT }} {{ .Env.USHELL_UE_BRANCH }} {{ end }} ",
          "foreground": "#3b7197",
          "background": "#00f7ff"
        },
        {
          "type": "node",
          "style": "powerline",
          "foreground": "#ffffff",
          "background": "#6CA35E",
          "template": " \ue718 ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "fetch_version": true
          }
        },
        {
          "type": "go",
          "style": "powerline",
          "foreground": "#111111",
          "background": "#8ED1F7",
          "template": " \ue626 ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "fetch_version": true
          }
        },
        {
          "type": "python",
          "style": "powerline",
          "foreground": "#111111",
          "background": "#FFDE57",
          "template": " \ue235 ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "display_mode": "environment",
            "fetch_virtual_env": true
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#193549",
          "background": "#05db34",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ffeb95{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#c5e478{{ end }}",
            "{{ if gt .Ahead 0 }}#C792EA{{ end }}",
            "{{ if gt .Behind 0 }}#C792EA{{ end }}"
          ],
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}{{ .Working.String }}{{ end }}{{ if .Staging.Changed }}{{ .Staging.String }}{{ end }} ",
          "options": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "foreground": "#ffffff",
          "background": "#8d47ff",
          "template": " \uea83 {{ .Path }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "home_icon": "~",
            "style": "agnoster_short"
          }
        },
        {
          "type": "root",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#ef5350",
          "foreground": "#FFFB38",
          "template": " \uf292 "
        }
      ]
    }
  ]
}
