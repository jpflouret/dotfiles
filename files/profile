export LC_COLLATE="C"

# Note: Bash on Windows does not currently apply umask properly.
if [ "$(umask)" = "0000" ]; then
  umask 022
fi

# if running bash
if [ -n "${BASH_VERSION}" ]; then
  if [ -f "${HOME}/.bashrc" ]; then
    source "${HOME}/.bashrc"
  fi
fi

# fix for synology shell set as /bin/sh
if [ "$BASH" == "/bin/sh" ]; then
  exec /bin/bash
fi

